---
// Landing Page / List of Projects
// import Layout from '../layouts/Layout.astro';
// Note: In a real implementation this might fetch from the local binding or relative API
// Using a mock fetch for demonstration
const projectsRes = await fetch('http://localhost:8787/api/projects').catch(() => ({ json: () => [] }));
const projects = await projectsRes.json();
---

<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Colby PMO - Projects</title>
    <!-- Add Tailwind via Astro configuration usually, placeholder inline for completeness if no layout -->
</head>
<body class="bg-zinc-950 text-zinc-50 font-sans antialiased">
  <main class="container mx-auto p-8">
    <h1 class="text-4xl font-bold mb-8">Projects</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.length === 0 ? (
        <p>No projects found. Create one via the Google Docs Add-on.</p>
      ) : (
        projects.map((p: any) => (
          <a href={`/projects/${p.id}`} class="block p-6 bg-zinc-900 border border-zinc-800 rounded-lg hover:bg-zinc-800 transition-colors">
            <h2 class="text-xl font-semibold mb-2">{p.name}</h2>
            <p class="text-zinc-400 text-sm">Created: {new Date(p.created_at).toLocaleDateString()}</p>
          </a>
        ))
      )}
    </div>
  </main>
</body>
</html>
