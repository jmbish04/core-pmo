---
const { id } = Astro.params;
import '../../../styles/global.css';
---

<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Project Details - {id}</title>
</head>
<body class="bg-[#131315] text-white font-sans antialiased min-h-screen flex flex-col">
    <header class="h-16 border-b border-[#1c1b1d] flex items-center justify-between px-8 bg-[#131315]">
        <div class="flex items-center gap-4">
            <a href="/" class="text-zinc-500 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </a>
            <h1 class="text-sm font-bold tracking-tighter text-zinc-400">PROJECT / <span class="text-white">{id}</span></h1>
        </div>
        <a href={`/projects/${id}/orchestrate`} class="bg-white text-black px-4 py-1.5 rounded-sm text-xs font-bold hover:bg-zinc-200 transition-colors">
            LAUNCH ORCHESTRATOR
        </a>
    </header>

    <main class="flex-1 max-w-6xl w-full mx-auto p-12">
        <h2 class="text-5xl font-bold tracking-tighter mb-8">System Overview</h2>

        <div class="grid grid-cols-3 gap-8">
            <!-- Details Column -->
            <div class="col-span-1 space-y-8">
                <div class="bg-[#1c1b1d] p-6 border border-[#2a2a2c]">
                    <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-4">Metadata</h3>
                    <dl class="space-y-4 text-sm">
                        <div>
                            <dt class="text-zinc-500 font-mono text-[10px] mb-1">REPOSITORY</dt>
                            <dd class="font-medium text-white truncate"><a href="#" class="hover:underline">github.com/org/repo</a></dd>
                        </div>
                        <div>
                            <dt class="text-zinc-500 font-mono text-[10px] mb-1">CLICKUP ID</dt>
                            <dd class="font-medium text-white">CU-9824</dd>
                        </div>
                    </dl>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="col-span-2 space-y-8">
                <section class="bg-[#1c1b1d] border border-[#2a2a2c] overflow-hidden">
                    <div class="h-12 border-b border-[#2a2a2c] flex items-center px-6 bg-[#201f22]">
                        <h3 class="text-sm font-semibold">Linked Documents</h3>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between p-4 border border-[#353437] bg-[#131315] rounded-sm hover:border-zinc-500 transition-colors cursor-pointer">
                            <div class="flex items-center gap-4">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>
                                <div>
                                    <h4 class="text-sm font-medium">Core Integration PRD</h4>
                                    <p class="text-[10px] text-zinc-500 font-mono mt-1">v2.4 • Linked 2 hours ago</p>
                                </div>
                            </div>
                            <button class="text-xs text-zinc-400 hover:text-white px-3 py-1 border border-[#353437] rounded-sm">Sync</button>
                        </div>
                    </div>
                </section>

                <section class="bg-[#1c1b1d] border border-[#2a2a2c] overflow-hidden">
                    <div class="h-12 border-b border-[#2a2a2c] flex items-center px-6 bg-[#201f22]">
                        <h3 class="text-sm font-semibold">Execution Tasks</h3>
                    </div>
                    <div class="divide-y divide-[#2a2a2c]">
                        <div class="flex items-center justify-between p-4 px-6 hover:bg-[#201f22] transition-colors">
                            <div class="flex items-center gap-4">
                                <div class="w-4 h-4 rounded-full border-2 border-zinc-600 flex-shrink-0"></div>
                                <span class="text-sm">Implement D1 Schema Migrations</span>
                            </div>
                            <span class="text-[10px] bg-[#353437] px-2 py-0.5 rounded-sm font-mono text-zinc-300">Jules</span>
                        </div>
                        <div class="flex items-center justify-between p-4 px-6 hover:bg-[#201f22] transition-colors">
                            <div class="flex items-center gap-4">
                                <div class="w-4 h-4 rounded-full border-2 border-zinc-600 flex-shrink-0 bg-white"></div>
                                <span class="text-sm text-zinc-500 line-through">Scaffold Hono Router</span>
                            </div>
                            <span class="text-[10px] bg-[#353437] px-2 py-0.5 rounded-sm font-mono text-zinc-300">Human</span>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>
</body>
</html>
