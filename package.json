{
  "name": "core-pmo",
  "version": "26.02.24",
  "description": "The template helps you build apps with Astro, Tailwind CSS, and shadcn/ui.",
  "license": "MIT",
  "author": {
    "name": "126colby",
    "url": "https://github.com/126colby"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmbish04/core-pmo"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && cp .assetsignore dist/.assetsignore",
    "preview": "pnpm dlx wrangler@latest dev",
    "start": "astro dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate",
    "db:seed:local": "npx wrangler d1 execute DB --local --file=src/backend/db/seed.sql",
    "db:seed:remote": "npx wrangler d1 execute DB --remote --file=src/backend/db/seed.sql",
    "migrate:local": "pnpm run db:generate && npx wrangler d1 migrations apply DB --local && pnpm run db:seed:local",
    "migrate:remote": "pnpm dlx wrangler@latest d1 migrations apply DB --remote",
    "deploy": "pnpm run build && pnpm run migrate:remote && pnpm dlx wrangler@latest deploy",
    "cf-typegen": "pnpm dlx wrangler@latest types",
    "gas:install": "cd gas-addon && pnpm install",
    "gas:build": "node scripts/gas-addon/build.js",
    "gas:validate": "node scripts/gas-addon/validate-config.js",
    "gas:push": "cd gas-addon && pnpm run push",
    "gas:deploy": "node scripts/gas-addon/deploy-prod.js"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@assistant-ui/react": "^0.12.26",
    "@assistant-ui/react-ai-sdk": "^1.3.20",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.4.2",
    "@base-ui/react": "^1.4.1",
    "@cloudflare/workers-types": "^4.20260425.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.10",
    "@tailwindcss/vite": "^4.2.4",
    "@udecode/plate-basic-elements": "^48.0.0",
    "@udecode/plate-basic-marks": "^48.0.0",
    "@udecode/plate-common": "^41.0.13",
    "@udecode/plate-core": "^48.0.5",
    "ai": "^6.0.168",
    "astro": "^5.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.15",
    "lucide-react": "^0.575.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.4.0",
    "slate": "^0.124.1",
    "slate-history": "^0.113.1",
    "slate-react": "^0.124.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.85.0"
  }
}
